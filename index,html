
<!DOCTYPE html>
<html>
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Student Portal</title>
<style>
  * { box-sizing: border-box; margin: 0; padding: 0; }
  body { font-family: sans-serif; background: #f0f0f0; min-height: 600px; display: flex; align-items: center; justify-content: center; }

  #login_page {
    background: white;
    border-radius: 18px;
    padding: 36px 32px;
    width: 300px;
    box-shadow: 0 4px 24px rgba(0,0,0,0.12);
    display: flex;
    flex-direction: column;
    align-items: center;
  }
  .logo-circle {
    width: 70px; height: 70px; border-radius: 50%;
    border: 3px solid #ddd;
    display: flex; align-items: center; justify-content: center;
    margin-bottom: 12px;
    background: white;
  }
  .logo-circle svg { width: 44px; height: 44px; }
  #login_page h2 { font-size: 22px; font-weight: 600; color: #222; margin-bottom: 18px; }
  .field-label {
    align-self: flex-start;
    background: #333; color: white;
    font-size: 11px; font-weight: 600;
    padding: 3px 10px; border-radius: 12px;
    margin-bottom: 5px; margin-top: 10px;
  }
  .login-input {
    width: 100%;
    padding: 10px 14px;
    border: none;
    border-radius: 8px;
    background: #e8e8e8;
    font-size: 14px;
    color: #444;
    outline: none;
  }
  .login-input:focus { background: #dde; }
  .stay-row { display: flex; align-items: center; gap: 8px; align-self: flex-start; margin-top: 12px; }
  .stay-row input { width: 14px; height: 14px; accent-color: #555; }
  .stay-row label { font-size: 13px; color: #555; }
  #msg { color: #c0392b; font-size: 12px; font-style: italic; min-height: 18px; text-align: center; margin-top: 8px; }
  .btn-row { display: flex; gap: 10px; margin-top: 14px; }
  .btn-login {
    background: #4a9fd4; color: white;
    border: none; border-radius: 20px;
    padding: 9px 22px; font-size: 14px; font-weight: 600;
    cursor: pointer;
  }
  .btn-login:hover { background: #3a8fc4; }
  .btn-cancel {
    background: none; color: #555;
    border: none; font-size: 14px; cursor: pointer;
    padding: 9px 8px;
  }
  .forgot { margin-top: 18px; font-size: 12px; color: #4a9fd4; text-decoration: underline; cursor: pointer; }

  #main_page {
    display: none;
    width: 680px;
    min-height: 520px;
    background: white;
    border-radius: 12px;
    overflow: hidden;
    box-shadow: 0 4px 24px rgba(0,0,0,0.13);
    flex-direction: row;
  }

  .sidebar {
    width: 140px;
    background: #1a1a2e;
    display: flex;
    flex-direction: column;
    align-items: center;
    padding: 20px 0 16px;
    flex-shrink: 0;
  }
  .sidebar-logo {
    width: 52px; height: 52px; border-radius: 50%;
    background: #2a2a4e;
    border: 2px solid #444;
    display: flex; align-items: center; justify-content: center;
    margin-bottom: 24px;
  }
  .sidebar-logo svg { width: 32px; height: 32px; }
  .nav-item {
    width: 100%; padding: 11px 18px;
    color: #aaa; font-size: 13px; cursor: pointer;
    transition: background 0.15s, color 0.15s;
    border: none; background: none; text-align: left;
  }
  .nav-item:hover { background: rgba(255,255,255,0.07); color: white; }
  .nav-item.active { color: white; background: rgba(255,255,255,0.08); font-weight: 600; }
  .sidebar-spacer { flex: 1; }
  .btn-logout {
    margin: 0 12px 8px;
    width: calc(100% - 24px);
    padding: 9px 0;
    background: rgba(255,255,255,0.08);
    color: #ccc;
    border: 1px solid rgba(255,255,255,0.15);
    border-radius: 8px;
    font-size: 13px;
    cursor: pointer;
    transition: background 0.15s, color 0.15s;
  }
  .btn-logout:hover { background: rgba(255,80,80,0.18); color: #ff8080; border-color: rgba(255,80,80,0.3); }

  .content-area {
    flex: 1;
    background: #e8e8e8;
    padding: 24px 22px;
    overflow-y: auto;
  }
  .content-header h3 { font-size: 20px; font-weight: 700; color: #222; letter-spacing: 1px; }
  .content-header p { font-size: 12px; color: #888; margin-top: 2px; }
  .subject-grid {
    display: grid;
    grid-template-columns: 1fr 1fr 1fr;
    gap: 12px;
    margin-top: 18px;
  }
  .subject-card {
    background: white;
    border-radius: 10px;
    padding: 10px;
    cursor: pointer;
    transition: box-shadow 0.15s;
    border: 0.5px solid #ddd;
  }
  .subject-card:hover { box-shadow: 0 2px 12px rgba(0,0,0,0.1); }
  .card-thumb {
    width: 100%; height: 60px;
    background: #d0d0d8;
    border-radius: 6px;
    margin-bottom: 8px;
    display: flex; align-items: center; justify-content: center;
  }
  .card-thumb svg { width: 28px; height: 28px; opacity: 0.5; }
  .card-title { font-size: 13px; font-weight: 700; color: #222; margin-bottom: 2px; }
  .card-sub { font-size: 11px; color: #888; margin-bottom: 2px; }
  .card-teacher { font-size: 11px; color: #555; }
  .card-bar { height: 4px; background: #ddd; border-radius: 2px; margin-top: 8px; }
  .card-bar-fill { height: 100%; background: #666; border-radius: 2px; }
</style>
</head>
<body>
<div id="login_page">
  <div class="logo-circle">
    <svg viewBox="0 0 44 44" fill="none" xmlns="http://www.w3.org/2000/svg">
      <circle cx="22" cy="22" r="20" stroke="#c8a83a" stroke-width="2.5"/>
      <path d="M10 20 L22 13 L34 20 L22 27 Z" fill="#1a3a8a" stroke="#1a3a8a" stroke-width="0.5"/>
      <path d="M34 20 L34 28" stroke="#1a3a8a" stroke-width="2" stroke-linecap="round"/>
      <path d="M15 24 L15 30 Q22 34 29 30 L29 24" fill="#c8a83a" stroke="#c8a83a" stroke-width="0.5"/>
    </svg>
  </div>
  <h2>Login</h2>
  <div class="field-label">Username</div>
  <input class="login-input" type="text" id="username" placeholder="student01">
  <div class="field-label">Password</div>
  <input class="login-input" type="password" id="password" placeholder="••••••••">
  <div class="stay-row">
    <input type="checkbox" id="stay">
    <label for="stay">Stay logged in</label>
  </div>
  <div id="msg"></div>
  <div class="btn-row">
    <button class="btn-login" onclick="doLogin()">Login</button>
    <button class="btn-cancel" onclick="document.getElementById('username').value='';document.getElementById('password').value='';document.getElementById('msg').textContent='';">Cancel</button>
  </div>
  <span class="forgot">Forgot username / password?</span>
</div>
<div id="main_page">
  <div class="sidebar">
    <div class="sidebar-logo">
      <svg viewBox="0 0 32 32" fill="none" xmlns="http://www.w3.org/2000/svg">
        <circle cx="16" cy="16" r="14" stroke="#c8a83a" stroke-width="1.8"/>
        <path d="M6 15 L16 9 L26 15 L16 21 Z" fill="#4a6fd4"/>
        <path d="M26 15 L26 21" stroke="#4a6fd4" stroke-width="1.5" stroke-linecap="round"/>
        <path d="M10 18 L10 22 Q16 25 22 22 L22 18" fill="#c8a83a"/>
      </svg>
    </div>
    <button class="nav-item">Dashboard</button>
    <button class="nav-item active">Virtual Notebooks</button>
    <button class="nav-item">Tasks</button>
    <button class="nav-item">Profile</button>
    <div class="sidebar-spacer"></div>
    <button class="btn-logout" onclick="doLogout()">Logout</button>
  </div>
  <div class="content-area">
    <div class="content-header">
      <h3>NOTEBOOKS</h3>
      <p>Select a subject.</p>
    </div>
    <div class="subject-grid">
      <div class="subject-card">
        <div class="card-thumb">
          <svg viewBox="0 0 28 28" fill="none"><rect x="4" y="6" width="20" height="16" rx="2" stroke="#555" stroke-width="1.5"/><line x1="8" y1="11" x2="20" y2="11" stroke="#555" stroke-width="1.2"/><line x1="8" y1="15" x2="16" y2="15" stroke="#555" stroke-width="1.2"/></svg>
        </div>
        <div class="card-title">Filipino</div>
        <div class="card-sub">9-Amethyst 2025–2026</div>
        <div class="card-teacher">Ms. Francisco</div>
        <div class="card-bar"><div class="card-bar-fill" style="width:55%"></div></div>
      </div>
      <div class="subject-card">
        <div class="card-thumb">
          <svg viewBox="0 0 28 28" fill="none"><rect x="4" y="6" width="20" height="16" rx="2" stroke="#555" stroke-width="1.5"/><line x1="8" y1="11" x2="20" y2="11" stroke="#555" stroke-width="1.2"/><line x1="8" y1="15" x2="16" y2="15" stroke="#555" stroke-width="1.2"/></svg>
        </div>
        <div class="card-title">English</div>
        <div class="card-sub">9-Amethyst 2025–2026</div>
        <div class="card-teacher">Ms. Avila</div>
        <div class="card-bar"><div class="card-bar-fill" style="width:70%"></div></div>
      </div>
      <div class="subject-card">
        <div class="card-thumb">
          <svg viewBox="0 0 28 28" fill="none"><circle cx="14" cy="14" r="8" stroke="#555" stroke-width="1.5"/><line x1="10" y1="14" x2="18" y2="14" stroke="#555" stroke-width="1.2"/><line x1="14" y1="10" x2="14" y2="18" stroke="#555" stroke-width="1.2"/></svg>
        </div>
        <div class="card-title">Math</div>
        <div class="card-sub">9-Amethyst 2025–2026</div>
        <div class="card-teacher">Mr. Verba</div>
        <div class="card-bar"><div class="card-bar-fill" style="width:40%"></div></div>
      </div>
      <div class="subject-card">
        <div class="card-thumb">
          <svg viewBox="0 0 28 28" fill="none"><path d="M14 6 C14 6 7 12 7 18 C7 22 10.5 24 14 24 C17.5 24 21 22 21 18 C21 12 14 6 14 6Z" stroke="#555" stroke-width="1.5" fill="none"/></svg>
        </div>
        <div class="card-title">Science</div>
        <div class="card-sub">9-Amethyst 2025–2026</div>
        <div class="card-teacher">Ms. Mendaro</div>
        <div class="card-bar"><div class="card-bar-fill" style="width:60%"></div></div>
      </div>
      <div class="subject-card">
        <div class="card-thumb">
          <svg viewBox="0 0 28 28" fill="none"><circle cx="14" cy="14" r="9" stroke="#555" stroke-width="1.5"/><line x1="5" y1="14" x2="23" y2="14" stroke="#555" stroke-width="1"/><path d="M14 5 Q19 14 14 23" stroke="#555" stroke-width="1" fill="none"/><path d="M14 5 Q9 14 14 23" stroke="#555" stroke-width="1" fill="none"/></svg>
        </div>
        <div class="card-title">Social Studies</div>
        <div class="card-sub">9-Amethyst 2025–2026</div>
        <div class="card-teacher">Mr. Reynoso</div>
        <div class="card-bar"><div class="card-bar-fill" style="width:50%"></div></div>
      </div>
      <div class="subject-card">
        <div class="card-thumb">
          <svg viewBox="0 0 28 28" fill="none"><path d="M14 8 L16.5 13 L22 13.5 L18 17.5 L19 23 L14 20 L9 23 L10 17.5 L6 13.5 L11.5 13 Z" stroke="#555" stroke-width="1.5" fill="none"/></svg>
        </div>
        <div class="card-title">Values Education</div>
        <div class="card-sub">9-Amethyst 2025–2026</div>
        <div class="card-teacher">Mr. Buntile</div>
        <div class="card-bar"><div class="card-bar-fill" style="width:80%"></div></div>
      </div>
    </div>
  </div>
</div>

<script>
var attempts = 0;
var locked = false;

function doLogin() {
  if (locked) return;
  var user = document.getElementById('username').value;
  var pass = document.getElementById('password').value;
  if (user === 'admin' && pass === 'pass123') {
    document.getElementById('login_page').style.display = 'none';
    document.getElementById('main_page').style.display = 'flex';
    attempts = 0;
    document.getElementById('msg').textContent = '';
  } else {
    attempts++;
    if (attempts >= 3) {
      locked = true;
      document.getElementById('msg').textContent = 'Too many attempts. Locked for 1 minute.';
      setTimeout(function() { locked = false; attempts = 0; document.getElementById('msg').textContent = ''; }, 60000);
    } else {
      document.getElementById('msg').textContent = 'Incorrect username and/or password. Attempt ' + attempts + ' of 3';
    }
  }
}

function doLogout() {
  document.getElementById('main_page').style.display = 'none';
  document.getElementById('login_page').style.display = 'flex';
  document.getElementById('username').value = '';
  document.getElementById('password').value = '';
  document.getElementById('msg').textContent = '';
  attempts = 0;
}

document.getElementById('password').addEventListener('keydown', function(e) {
  if (e.key === 'Enter') doLogin();
});
document.getElementById('username').addEventListener('keydown', function(e) {
  if (e.key === 'Enter') doLogin();
});
</script>
</body>
</html>
